# ─── Payload / Postgres ─────────────────────────────────────────────────────
# Postgres connection string. In production this is the Hostinger VPS
# Postgres (same Docker network as Frappe ERPNext). Locally you can point
# at a local Postgres instance or a staging DB.
DATABASE_URI=postgres://user:password@localhost:5432/dgtl_platform

# Payload auth secret — any random 32+ char string. Rotate if exposed.
# Generate with: openssl rand -hex 32
PAYLOAD_SECRET=change-me-to-a-long-random-string

# ─── Cloudinary (media CDN) ─────────────────────────────────────────────────
# All three required to enable the cloudinary storage plugin. If any is
# missing, Payload falls back to local disk storage (handy for dev without
# Cloudinary credentials).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Frappe ERPNext (dashboard integration, Phase 06) ───────────────────────
FRAPPE_BASE_URL=https://erp.dgtlgroup.io
FRAPPE_API_KEY=
FRAPPE_API_SECRET=

# ─── SendMails (newsletter subscription) ────────────────────────────────────
# API token from sendmails.io account, list UID for the DGTL newsletter list
SENDMAILS_API_TOKEN=
SENDMAILS_LIST_UID=

# ─── Email (AWS SES SMTP, Phase 01) ─────────────────────────────────────────
# DGTL's SES is provisioned in eu-west-3 (Paris). Use STARTTLS on port 587.
SMTP_HOST=email-smtp.eu-west-3.amazonaws.com
SMTP_PORT=587
SMTP_SECURITY=STARTTLS
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@dgtlgroup.io
