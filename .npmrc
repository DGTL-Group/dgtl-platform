# ── pnpm-only settings (ignored by npm) ──────────────────────────────────────
# These are read by pnpm for local dev. npm warns about them but they're
# harmless — the actual workspace config npm uses is "workspaces" in package.json.
link-workspace-packages=true
prefer-workspace-packages=true
shared-workspace-lockfile=true
public-hoist-pattern[]=*react*
public-hoist-pattern[]=*next*
public-hoist-pattern[]=*payload*
public-hoist-pattern[]=@types/*

# ── Shared settings (both npm and pnpm) ──────────────────────────────────────
engine-strict=false
