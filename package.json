{
  "name": "dgtl-platform",
  "version": "0.1.0",
  "private": true,
  "description": "DGTL Group platform monorepo — dgtlgroup.io rebuild + dashboard.dgtlgroup.io client portal",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @dgtl/web dev",
    "build": "pnpm --filter @dgtl/web build",
    "start": "pnpm --filter @dgtl/web start",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r exec tsc --noEmit"
  },
  "packageManager": "pnpm@10.33.0"
}
